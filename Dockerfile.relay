FROM golang:1.26 AS builder

COPY . /warpnet
WORKDIR /warpnet

ENV CGO_ENABLED=0

RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -ldflags "-s -w" -gcflags=all=-l -mod=vendor -v -o warpnet cmd/node/relay/main.go

FROM gcr.io/distroless/static-debian12
COPY --from=builder /warpnet/warpnet /warpnet/warpnet
CMD ["/warpnet/warpnet"]
