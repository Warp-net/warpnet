#!/bin/bash

set -euo pipefail

if [ "$(git rev-parse --abbrev-ref HEAD)" = "main" ]; then
    exit 0
fi

echo "Pre-commit hook started..."

CONFIG="version"
SNAPCRAFT="snap/snapcraft.yaml"

if [ ! -f "$CONFIG" ]; then
    echo "Config file not found!"
    exit 1
fi

if [ ! -f "$SNAPCRAFT" ]; then
    echo "Snapcraft file not found: $SNAPCRAFT"
    exit 1
fi

CURRENT_VERSION=$(grep -Eo '^[0-9]+\.[0-9]+\.[0-9]+' "$CONFIG")
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT_VERSION"

echo "CURRENT_VERSION=$CURRENT_VERSION"
echo "PATCH=$PATCH"

PATCH=$((PATCH + 1))
NEW_VERSION="$MAJOR.$MINOR.$PATCH"


sed -i "s/^$CURRENT_VERSION\$/$NEW_VERSION/" "$CONFIG"
sed -i -E "s/^version:[[:space:]]*'?([0-9]+\.[0-9]+\.[0-9]+)'?/version: ${NEW_VERSION}/" "$SNAPCRAFT"

git add "$CONFIG" "$SNAPCRAFT"

# Keep the warpdroid F-Droid fastlane changelog filenames in sync with the new
# versionCode. The published versionCode mirrors warpdroid/app/build.gradle:
#   base = major*1000000 + minor*10000 + patch, then *10 + ABI offset
#   (armeabi-v7a=1, x86_64=2, arm64-v8a=3, ascending).
CHANGELOGS="warpdroid/fastlane/metadata/android/en-US/changelogs"
if [ -d "$CHANGELOGS" ]; then
    NEW_BASE=$(( (10#$MAJOR * 1000000 + 10#$MINOR * 10000 + 10#$PATCH) * 10 ))
    OFFSET=1
    for OLD in $(ls "$CHANGELOGS"/*.txt 2>/dev/null | sort -V); do
        NEW="$CHANGELOGS/$((NEW_BASE + OFFSET)).txt"
        if [ "$OLD" != "$NEW" ]; then
            mv -f "$OLD" "$NEW"
            echo "Changelog: $(basename "$OLD") -> $(basename "$NEW")"
        fi
        OFFSET=$((OFFSET + 1))
    done
    git add "$CHANGELOGS"
fi


