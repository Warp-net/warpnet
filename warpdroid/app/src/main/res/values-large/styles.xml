<resources>
    <style name="WarpdroidDialogActivityTheme" parent="@style/WarpdroidTheme">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@drawable/background_dialog_activity</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowSoftInputMode">stateAlwaysVisible|adjustResize</item>
        <item name="android:windowCloseOnTouchOutside">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="WarpdroidDialogActivityBlackTheme" parent="@style/WarpdroidBlackTheme">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@drawable/background_dialog_activity</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowSoftInputMode">stateAlwaysVisible|adjustResize</item>
        <item name="android:windowCloseOnTouchOutside">false</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

</resources>
