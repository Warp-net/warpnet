<?xml version="1.0" encoding="utf-8"?>
<!-- The W glyph fills ~76% of the icon canvas, which spills outside the 66dp
     adaptive-icon safe zone. Standard launchers tolerate it, but Nothing OS
     (and other themed-icon masks) crop the monochrome layer to that safe
     circle, clipping the bottom of the W. Inset the glyph so it fits. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/launcher_monochrome"
    android:insetLeft="16dp"
    android:insetTop="16dp"
    android:insetRight="16dp"
    android:insetBottom="16dp" />
